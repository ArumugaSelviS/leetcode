/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public int goodNodes(TreeNode root) {
        {
        return countGN(root, Integer.MIN_VALUE); 
    }
    }
    private int countGN(TreeNode node,int maxVal)
    {
        
        if(node==null)
        {
            return 0;
        }
        int count=0;
        if(node.val>=maxVal)
        {
            count=1;
        }
        else
        {
            count=0;
        }
        if(node.val>maxVal)
        {
            maxVal=node.val;
        }
        count+=countGN(node.left,maxVal);
        count+=countGN(node.right,maxVal);
        return count;

    }
        
    }
